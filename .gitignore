# =============================================================
# Unity .gitignore
# =============================================================

# Generated / cache folders (rebuilt by Unity, never commit)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data should ONLY be ignored if the asset is also ignored
!/[Aa]ssets/**/*.meta

# Don't ignore Packages folder, but ignore its lock-less generated bits
/[Aa]ssets/AssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# Autogenerated Visual Studio / Rider / IDE files
.vs/
.idea/
.vscode/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity build output
*.apk
*.aab
*.unitypackage
*.app

# Crash report files
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# Addressables generated content
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Rider-specific
*.sln.iml